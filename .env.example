APP_NAME=ePlayHD
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eplayhd
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_DRIVER=database
QUEUE_CONNECTION=database

BROADCAST_DRIVER=log

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@eplayhd.com"
MAIL_FROM_NAME="${APP_NAME}"

# Cricket API
CRICKET_API_KEY=
CRICKET_API_ENABLED=false

# RapidAPI
RAPID_API_KEY=
RAPID_API_ENABLED=false

# Google Analytics
GOOGLE_ANALYTICS_ID=

# Google AdSense
GOOGLE_ADSENSE_ID=
